{
  "project": "Urban Heat AI — ISRO Bharatiya Antariksh Hackathon",
  "version": "2.0",
  "generated_from": "Google Earth Engine main.js pipeline",
  "crs": "EPSG:4326",
  "export_resolution_m": 30,
  "csv_sample_spacing_m": 100,
  "total_features": 37,
  "target_variable": "LST",
  "features": [
    {
      "name": "PixelID",
      "category": "metadata",
      "type": "integer",
      "units": null,
      "min": 0,
      "max": null,
      "source": "generated",
      "description": "Sequential identifier for each sampled pixel"
    },
    {
      "name": "Latitude",
      "category": "metadata",
      "type": "float",
      "units": "degrees",
      "min": 6.0,
      "max": 38.0,
      "source": "geometry",
      "description": "WGS84 latitude (Y coordinate)"
    },
    {
      "name": "Longitude",
      "category": "metadata",
      "type": "float",
      "units": "degrees",
      "min": 68.0,
      "max": 98.0,
      "source": "geometry",
      "description": "WGS84 longitude (X coordinate)"
    },
    {
      "name": "Timestamp",
      "category": "metadata",
      "type": "string",
      "units": null,
      "min": null,
      "max": null,
      "source": "config",
      "description": "Date range of the composite period (e.g. 2024-03-01_to_2024-06-30)"
    },
    {
      "name": "LST",
      "category": "target",
      "type": "float",
      "units": "Celsius",
      "min": -10.0,
      "max": 70.0,
      "source": "LANDSAT/LC08/C02/T1_L2 + LANDSAT/LC09/C02/T1_L2",
      "band": "ST_B10",
      "formula": "ST_B10 * 0.00341802 + 149.0 - 273.15",
      "description": "Land Surface Temperature from Landsat-8/9 thermal band"
    },
    {
      "name": "NDVI",
      "category": "spectral_index",
      "type": "float",
      "units": "dimensionless",
      "min": -1.0,
      "max": 1.0,
      "source": "LANDSAT/LC08/C02/T1_L2",
      "formula": "(SR_B5 - SR_B4) / (SR_B5 + SR_B4)",
      "reference": "Tucker (1979), Rouse et al. (1974)",
      "description": "Normalized Difference Vegetation Index — measures vegetation health"
    },
    {
      "name": "NDBI",
      "category": "spectral_index",
      "type": "float",
      "units": "dimensionless",
      "min": -1.0,
      "max": 1.0,
      "source": "LANDSAT/LC08/C02/T1_L2",
      "formula": "(SR_B6 - SR_B5) / (SR_B6 + SR_B5)",
      "reference": "Zha et al. (2003)",
      "description": "Normalized Difference Built-up Index — highlights impervious surfaces"
    },
    {
      "name": "NDWI",
      "category": "spectral_index",
      "type": "float",
      "units": "dimensionless",
      "min": -1.0,
      "max": 1.0,
      "source": "LANDSAT/LC08/C02/T1_L2",
      "formula": "(SR_B3 - SR_B5) / (SR_B3 + SR_B5)",
      "reference": "McFeeters (1996)",
      "description": "Normalized Difference Water Index — detects open water"
    },
    {
      "name": "MNDWI",
      "category": "spectral_index",
      "type": "float",
      "units": "dimensionless",
      "min": -1.0,
      "max": 1.0,
      "source": "LANDSAT/LC08/C02/T1_L2",
      "formula": "(SR_B3 - SR_B6) / (SR_B3 + SR_B6)",
      "reference": "Xu (2006)",
      "description": "Modified NDWI — better urban water detection using SWIR"
    },
    {
      "name": "Albedo",
      "category": "spectral_index",
      "type": "float",
      "units": "dimensionless",
      "min": 0.0,
      "max": 1.0,
      "source": "LANDSAT/LC08/C02/T1_L2",
      "formula": "0.356*B2 + 0.130*B4 + 0.373*B5 + 0.085*B6 + 0.072*B7 - 0.0018",
      "reference": "Liang (2001)",
      "description": "Shortwave surface albedo — ratio of reflected to incoming solar radiation"
    },
    {
      "name": "LULC_ESA",
      "category": "land_cover",
      "type": "integer",
      "units": "class_code",
      "min": 10,
      "max": 100,
      "source": "ESA/WorldCover/v200",
      "resolution_m": 10,
      "classes": {
        "10": "Tree Cover",
        "20": "Shrubland",
        "30": "Grassland",
        "40": "Cropland",
        "50": "Built-up",
        "60": "Bare/Sparse",
        "70": "Snow/Ice",
        "80": "Water",
        "90": "Herbaceous Wetland",
        "95": "Mangroves",
        "100": "Moss/Lichen"
      },
      "reference": "Zanaga et al. (2022)",
      "description": "ESA WorldCover v200 land use/land cover class"
    },
    {
      "name": "LULC_DW",
      "category": "land_cover",
      "type": "integer",
      "units": "class_code",
      "min": 0,
      "max": 8,
      "source": "GOOGLE/DYNAMICWORLD/V1",
      "resolution_m": 10,
      "classes": {
        "0": "Water",
        "1": "Trees",
        "2": "Grass",
        "3": "Flooded Vegetation",
        "4": "Crops",
        "5": "Shrub/Scrub",
        "6": "Built Area",
        "7": "Bare Ground",
        "8": "Snow/Ice"
      },
      "reference": "Brown et al. (2022)",
      "description": "Google Dynamic World ML-based land cover class (mode over date range)"
    },
    {
      "name": "Impervious_Frac",
      "category": "land_cover",
      "type": "integer",
      "units": "binary",
      "min": 0,
      "max": 1,
      "source": "Tsinghua/FROM-GLC/GAIA/v10",
      "resolution_m": 30,
      "reference": "Gong et al. (2020)",
      "description": "Impervious surface indicator (1=impervious, 0=pervious)"
    },
    {
      "name": "Tree_Cover_Pct",
      "category": "land_cover",
      "type": "float",
      "units": "percent",
      "min": 0.0,
      "max": 100.0,
      "source": "UMD/hansen/global_forest_change_2023_v1_11",
      "band": "treecover2000",
      "resolution_m": 30,
      "reference": "Hansen et al. (2013)",
      "description": "Tree canopy cover percentage in year 2000"
    },
    {
      "name": "AirTemp",
      "category": "weather",
      "type": "float",
      "units": "Celsius",
      "min": -10.0,
      "max": 60.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "band": "temperature_2m",
      "formula": "temperature_2m - 273.15",
      "resolution_m": 11000,
      "description": "2-meter air temperature from ERA5-Land reanalysis"
    },
    {
      "name": "Humidity",
      "category": "weather",
      "type": "float",
      "units": "percent",
      "min": 0.0,
      "max": 100.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "formula": "100 * exp(17.625*Td/(243.04+Td)) / exp(17.625*T/(243.04+T))",
      "reference": "Alduchov & Eskridge (1996) Magnus formula",
      "resolution_m": 11000,
      "description": "Relative humidity derived from air and dewpoint temperature"
    },
    {
      "name": "WindSpeed",
      "category": "weather",
      "type": "float",
      "units": "m/s",
      "min": 0.0,
      "max": 30.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "formula": "sqrt(u10^2 + v10^2)",
      "resolution_m": 11000,
      "description": "10-meter wind speed magnitude"
    },
    {
      "name": "WindDirection",
      "category": "weather",
      "type": "float",
      "units": "degrees",
      "min": 0.0,
      "max": 360.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "formula": "atan2(-u10, -v10) * 180/pi + 180",
      "resolution_m": 11000,
      "description": "Wind direction (meteorological convention: FROM which wind blows)"
    },
    {
      "name": "SolarRadiation",
      "category": "weather",
      "type": "float",
      "units": "W/m2",
      "min": 0.0,
      "max": 500.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "band": "surface_solar_radiation_downwards_hourly",
      "formula": "mean(ssrd_hourly) / 3600",
      "resolution_m": 11000,
      "description": "Mean downward shortwave solar radiation at surface"
    },
    {
      "name": "Pressure",
      "category": "weather",
      "type": "float",
      "units": "hPa",
      "min": 800.0,
      "max": 1100.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "band": "surface_pressure",
      "formula": "surface_pressure / 100",
      "resolution_m": 11000,
      "description": "Surface atmospheric pressure"
    },
    {
      "name": "Rainfall",
      "category": "weather",
      "type": "float",
      "units": "mm",
      "min": 0.0,
      "max": 5000.0,
      "source": "ECMWF/ERA5_LAND/HOURLY",
      "band": "total_precipitation_hourly",
      "formula": "sum(total_precipitation_hourly) * 1000",
      "resolution_m": 11000,
      "description": "Total accumulated precipitation over the study period"
    },
    {
      "name": "Elevation",
      "category": "terrain",
      "type": "float",
      "units": "meters",
      "min": -100.0,
      "max": 9000.0,
      "source": "USGS/SRTMGL1_003",
      "resolution_m": 30,
      "reference": "Farr et al. (2007)",
      "description": "Terrain elevation above sea level"
    },
    {
      "name": "Slope",
      "category": "terrain",
      "type": "float",
      "units": "degrees",
      "min": 0.0,
      "max": 90.0,
      "source": "USGS/SRTMGL1_003",
      "formula": "ee.Terrain.products(srtm).select('slope')",
      "resolution_m": 30,
      "description": "Terrain slope angle"
    },
    {
      "name": "Aspect",
      "category": "terrain",
      "type": "float",
      "units": "degrees",
      "min": 0.0,
      "max": 360.0,
      "source": "USGS/SRTMGL1_003",
      "formula": "ee.Terrain.products(srtm).select('aspect')",
      "resolution_m": 30,
      "description": "Terrain aspect (compass direction the slope faces)"
    },
    {
      "name": "Building_Density",
      "category": "urban_morphology",
      "type": "float",
      "units": "fraction_or_m2",
      "min": 0.0,
      "max": null,
      "source": "JRC/GHSL/P2023A/GHS_BUILT_S",
      "resolution_m": 10,
      "reference": "Pesaresi et al. (2023)",
      "description": "Built-up surface fraction per pixel from GHSL"
    },
    {
      "name": "Building_Height",
      "category": "urban_morphology",
      "type": "float",
      "units": "meters",
      "min": 0.0,
      "max": 500.0,
      "source": "JRC/GHSL/P2023A/GHS_BUILT_H",
      "resolution_m": 100,
      "reference": "Pesaresi et al. (2023)",
      "description": "Average building height from GHSL"
    },
    {
      "name": "Building_Volume",
      "category": "urban_morphology",
      "type": "float",
      "units": "m3_per_pixel",
      "min": 0.0,
      "max": null,
      "source": "derived",
      "formula": "Building_Density * Building_Height",
      "description": "Building volume proxy (density times height)"
    },
    {
      "name": "Nighttime_Lights",
      "category": "urban_morphology",
      "type": "float",
      "units": "nW/cm2/sr",
      "min": 0.0,
      "max": 500.0,
      "source": "NOAA/VIIRS/DNB/MONTHLY_V1/VCMSLCFG",
      "band": "avg_rad",
      "resolution_m": 500,
      "reference": "Elvidge et al. (2017)",
      "description": "VIIRS nighttime light radiance — proxy for urban activity"
    },
    {
      "name": "Population_Density",
      "category": "urban_morphology",
      "type": "float",
      "units": "people_per_pixel",
      "min": 0.0,
      "max": null,
      "source": "WorldPop/GP/100m/pop",
      "resolution_m": 100,
      "reference": "Tatem (2017)",
      "description": "UN-adjusted gridded population count"
    },
    {
      "name": "Dist_Water",
      "category": "distance",
      "type": "float",
      "units": "meters",
      "min": 0.0,
      "max": null,
      "source": "derived",
      "formula": "fastDistanceTransform(NDWI > 0) * pixel_scale",
      "description": "Euclidean distance to nearest water pixel (NDWI > 0)"
    },
    {
      "name": "Dist_Green",
      "category": "distance",
      "type": "float",
      "units": "meters",
      "min": 0.0,
      "max": null,
      "source": "derived",
      "formula": "fastDistanceTransform(NDVI > 0.4) * pixel_scale",
      "description": "Euclidean distance to nearest green space pixel (NDVI > 0.4)"
    },
    {
      "name": "Green_Space_Density",
      "category": "derived",
      "type": "float",
      "units": "fraction",
      "min": 0.0,
      "max": 1.0,
      "source": "derived",
      "formula": "reduceNeighborhood(mean, NDVI > 0.3, circle_5px)",
      "description": "Fraction of green pixels within 150m circular neighborhood"
    },
    {
      "name": "Surface_Roughness",
      "category": "derived",
      "type": "float",
      "units": "meters",
      "min": 0.0,
      "max": null,
      "source": "derived",
      "formula": "reduceNeighborhood(stdDev, Elevation, circle_5px)",
      "description": "Standard deviation of elevation in 150m neighborhood"
    },
    {
      "name": "Anthropogenic_Heat",
      "category": "derived",
      "type": "float",
      "units": "unitless",
      "min": 0.0,
      "max": null,
      "source": "derived",
      "formula": "unitScale(Nighttime_Lights, 0, 100) * unitScale(Population_Density, 0, 10000)",
      "reference": "Chen et al. (2014), Dong et al. (2017)",
      "description": "Anthropogenic heat proxy from nightlights and population"
    },
    {
      "name": "Road_Density_Proxy",
      "category": "derived",
      "type": "float",
      "units": "unitless",
      "min": -1.0,
      "max": 1.0,
      "source": "derived",
      "formula": "Impervious_Frac - (LULC_ESA == 50)",
      "description": "Road density estimate (impervious minus buildings)"
    },
    {
      "name": "UHI_Intensity",
      "category": "heat_index",
      "type": "float",
      "units": "Celsius",
      "min": -20.0,
      "max": 25.0,
      "source": "derived",
      "formula": "LST - mean(LST where LULC_ESA != 50)",
      "reference": "Oke (1982)",
      "description": "Urban Heat Island intensity relative to rural mean temperature"
    },
    {
      "name": "UTFVI",
      "category": "heat_index",
      "type": "float",
      "units": "dimensionless",
      "min": -1.0,
      "max": 1.0,
      "source": "derived",
      "formula": "(LST - mean_LST) / mean_LST",
      "reference": "Guha et al. (2018)",
      "classification": {
        "< 0": "None (Excellent ecological quality)",
        "0 - 0.005": "Weak (Good)",
        "0.005 - 0.010": "Moderate (Normal)",
        "0.010 - 0.015": "Strong (Bad)",
        "0.015 - 0.020": "Stronger (Worse)",
        "> 0.020": "Strongest (Worst)"
      },
      "description": "Urban Thermal Field Variance Index"
    },
    {
      "name": "QualityScore",
      "category": "quality",
      "type": "integer",
      "units": "count",
      "min": 0,
      "max": null,
      "source": "derived",
      "formula": "landsatMerged.select('SR_B4').count()",
      "description": "Number of valid Landsat observations used in median composite"
    }
  ]
}
